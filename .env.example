# Shared
NODE_ENV=development
LOG_LEVEL=debug

# Infrastructure
DATABASE_URL=postgresql://cpv:cpv@localhost:5432/cpv?schema=public
REDIS_URL=redis://localhost:6379

# Server
PORT=4000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=replace-with-a-long-random-secret-for-local-dev
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12
EXECUTION_TIME_LIMIT_MS=2000
EXECUTION_MEMORY_LIMIT_MB=256
DOCKER_IMAGE_CPP=gcc:14
DOCKER_IMAGE_PYTHON=python:3.13-slim
DOCKER_IMAGE_JAVA=eclipse-temurin:21

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=CPV
