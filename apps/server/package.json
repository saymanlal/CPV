{
  "name": "@cpv/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env --clear-screen=false src/index.ts",
    "build": "tsup src/index.ts src/app.ts --format esm --dts false",
    "start": "node dist/index.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@cpv/config": "workspace:*",
    "@cpv/contracts": "workspace:*",
    "@cpv/database": "workspace:*",
    "@cpv/logger": "workspace:*",
    "@fastify/cors": "11.1.0",
    "@fastify/jwt": "9.1.0",
    "bcrypt": "6.0.0",
    "fastify": "5.5.0",
    "socket.io": "4.8.1"
  },
  "devDependencies": {
    "@types/bcrypt": "6.0.0",
    "@types/node": "24.5.2",
    "tsup": "8.5.0",
    "tsx": "4.20.5",
    "typescript": "5.9.2"
  }
}
